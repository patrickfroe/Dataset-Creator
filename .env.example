# Pflichtfelder (Azure OpenAI)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Optional, aber empfohlen explizit zu setzen
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optionale Overrides
RAGAS_INPUT_DIR=data/raw
RAGAS_FILE_TYPES=pdf,docx,md,txt
RAGAS_OUTPUT_FORMATS=xlsx
RAGAS_LANGUAGE=de
RAGAS_CHUNK_SIZE=800
RAGAS_CHUNK_OVERLAP=120
RAGAS_TESTSET_SIZE=50
RAGAS_RANDOM_SEED=42
